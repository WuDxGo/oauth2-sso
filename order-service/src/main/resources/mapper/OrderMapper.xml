<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.oauth.order.mapper.OrderMapper">

    <resultMap id="BaseResultMap" type="com.example.oauth.order.entity.Order">
        <id column="id" property="id"/>
        <result column="order_no" property="orderNo"/>
        <result column="user_id" property="userId"/>
        <result column="amount" property="amount"/>
        <result column="status" property="status"/>
        <result column="description" property="description"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 根据 ID 查询订单 -->
    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM t_order WHERE id = #{id}
    </select>

    <!-- 查询所有订单 -->
    <select id="findAll" resultMap="BaseResultMap">
        SELECT * FROM t_order ORDER BY create_time DESC
    </select>

    <!-- 根据用户 ID 查询订单 -->
    <select id="findByUserId" resultMap="BaseResultMap">
        SELECT * FROM t_order WHERE user_id = #{userId} ORDER BY create_time DESC
    </select>

    <!-- 插入订单 -->
    <insert id="insert" parameterType="com.example.oauth.order.entity.Order" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_order (
            order_no, user_id, amount, status, description, create_time, update_time
        ) VALUES (
            #{orderNo}, #{userId}, #{amount}, #{status}, #{description}, NOW(), NOW()
        )
    </insert>

    <!-- 更新订单 -->
    <update id="update" parameterType="com.example.oauth.order.entity.Order">
        UPDATE t_order SET
            amount = #{amount},
            status = #{status},
            description = #{description},
            update_time = NOW()
        WHERE id = #{id}
    </update>

    <!-- 删除订单 -->
    <delete id="deleteById">
        DELETE FROM t_order WHERE id = #{id}
    </delete>
</mapper>
